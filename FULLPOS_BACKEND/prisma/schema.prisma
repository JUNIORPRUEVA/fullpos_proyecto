generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 Int              @id @default(autoincrement())
  name               String
  rnc                String?
  cloudCompanyId     String?          @unique
  tenantKey          String?          @unique
  normalizedRnc      String?
  sourceBusinessId   String?
  primaryDeviceId    String?
  isActive           Boolean          @default(true)
  ownerAppAndroidUrl String?
  ownerAppIosUrl     String?
  ownerAppVersion    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  users          User[]
  terminals      Terminal[]
  overrideTokens OverrideToken[]
  overrideRequests OverrideRequest[]
  auditLogs      AuditLog[]
  sales          Sale[]
  returns        Return[]
  cashSessions   CashSession[]
  cashMovements  CashMovement[]
  payments       Payment[]
  products       Product[]
  expenses       Expense[]
  quotes         Quote[]
  cloudBackups   CloudBackup[]
  clients        Client[]
  categories     Category[]
  suppliers      Supplier[]
  electronicInvoices ElectronicInvoice[]
  electronicSequences ElectronicSequence[]
  electronicCertificates ElectronicCertificate[]
  electronicInboundEndpointConfigs ElectronicInboundEndpointConfig[]
  electronicDgiiTokenCaches ElectronicDgiiTokenCache[]
  electronicAuditLogs ElectronicAuditLog[]
  electronicAuthSeeds ElectronicAuthSeed[]
  dgiiCertificationBatches DgiiCertificationBatch[]
  dgiiCertificationCases DgiiCertificationCase[]

  integrationTokens IntegrationToken[]

  config CompanyConfig?

  @@unique([name])
  @@index([normalizedRnc])
}

model Client {
  id         Int      @id @default(autoincrement())
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])
  localId    Int?
  nombre     String
  telefono   String?
  direccion  String?
  rnc        String?
  cedula     String?
  isActive   Boolean  @default(true)
  hasCredit  Boolean  @default(false)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, localId])
  @@index([companyId, updatedAt])
}

model Category {
  id         Int      @id @default(autoincrement())
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])
  localId    Int?
  name       String
  isActive   Boolean  @default(true)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, localId])
  @@index([companyId, updatedAt])
}

model Supplier {
  id         Int      @id @default(autoincrement())
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])
  localId    Int?
  name       String
  phone      String?
  note       String?
  isActive   Boolean  @default(true)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, localId])
  @@index([companyId, updatedAt])
}

model CloudBackup {
  id          String   @id @default(uuid())
  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  sizeBytes   Int
  sha256      String
  dbVersion   Int
  appVersion  String
  storagePath String
  status      String   @default("SUCCESS")

  @@index([companyId, createdAt])
}

model CompanyConfig {
  companyId     Int      @id
  company       Company  @relation(fields: [companyId], references: [id])
  logoUrl       String?
  phone         String?
  phone2        String?
  email         String?
  address       String?
  city          String?
  slogan        String?
  website       String?
  instagramUrl  String?
  facebookUrl   String?
  themeKey      String   @default("proPos")
  primaryColor  String?
  accentColor   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id                Int               @id @default(autoincrement())
  companyId         Int
  company           Company           @relation(fields: [companyId], references: [id])
  username          String            @unique
  email             String?           @unique
  password          String
  role              String            @default("owner")
  isActive          Boolean           @default(true)
  displayName       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  overrideRequests  OverrideRequest[] @relation("requested_by")
  overrideApprovals OverrideRequest[] @relation("approved_by")
  tokensUsed        OverrideToken[]   @relation("token_used_by")
  tokensApproved    OverrideToken[]   @relation("token_approved_by")
  auditsRequested   AuditLog[]        @relation("audit_requested_by")
  auditsApproved    AuditLog[]        @relation("audit_approved_by")
  refreshTokens     RefreshToken[]
  sales             Sale[]            @relation("sale_created_by")
  cashSessionsOpened CashSession[]    @relation("session_opened_by")
  cashSessionsClosed CashSession[]    @relation("session_closed_by")
  expensesCreated   Expense[]         @relation("expense_created_by")
}

model Terminal {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])
  deviceId  String   @unique
  name      String?
  lastSeen  DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OverrideRequest {
  id             Int       @id @default(autoincrement())
  companyId      Int
  company        Company   @relation(fields: [companyId], references: [id])
  actionCode     String
  resourceType   String?
  resourceId     String?
  status         String    @default("pending") // pending | approved | rejected
  requestedById  Int
  requestedBy    User      @relation("requested_by", fields: [requestedById], references: [id])
  approvedById   Int?
  approvedBy     User?     @relation("approved_by", fields: [approvedById], references: [id])
  terminalId     String?
  tokenHash      String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  meta           Json?

  token          OverrideToken?
}

model OverrideToken {
  id            Int       @id @default(autoincrement())
  companyId     Int
  company       Company   @relation(fields: [companyId], references: [id])
  actionCode    String
  resourceType  String?
  resourceId    String?
  tokenHash     String
  method        String
  nonce         String
  requestedById Int
  approvedById  Int?
  expiresAt     DateTime
  revokedAt     DateTime?
  usedAt        DateTime?
  usedById      Int?
  terminalId    String?
  result        String?
  meta          Json?
  createdAt     DateTime  @default(now())

  requestId     Int?     @unique
  request       OverrideRequest? @relation(fields: [requestId], references: [id])

  usedBy        User?     @relation("token_used_by", fields: [usedById], references: [id])
  approvedBy    User?     @relation("token_approved_by", fields: [approvedById], references: [id])

  @@index([companyId, actionCode, expiresAt])
  @@unique([companyId, tokenHash, method])
}

model AuditLog {
  id             Int      @id @default(autoincrement())
  companyId      Int
  company        Company  @relation(fields: [companyId], references: [id])
  actionCode     String
  resourceType   String?
  resourceId     String?
  requestedById  Int?
  approvedById   Int?
  method         String?
  result         String
  terminalId     String?
  meta           Json?
  createdAt      DateTime @default(now())

  requestedBy    User?    @relation("audit_requested_by", fields: [requestedById], references: [id])
  approvedBy     User?    @relation("audit_approved_by", fields: [approvedById], references: [id])

  @@index([companyId, actionCode, createdAt])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId, expiresAt])
}

model IntegrationToken {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])
  name      String?
  tokenHash String   @unique
  scopes    String[]
  createdAt DateTime @default(now())
  expiresAt DateTime?
  revokedAt DateTime?
  lastUsedAt DateTime?

  @@index([companyId, revokedAt])
}

model CashSession {
  id             Int       @id @default(autoincrement())
  companyId      Int
  company        Company   @relation(fields: [companyId], references: [id])
  // ID local del POS (SQLite) para poder sincronizar sin duplicar
  localId         Int?
  openedById     Int
  openedBy       User      @relation("session_opened_by", fields: [openedById], references: [id])
  closedById     Int?
  closedBy       User?     @relation("session_closed_by", fields: [closedById], references: [id])
  userName       String
  openedAt       DateTime
  closedAt       DateTime?
  initialAmount  Decimal   @default(0) @db.Decimal(12, 2)
  closingAmount  Decimal?  @db.Decimal(12, 2)
  expectedCash   Decimal?  @db.Decimal(12, 2)
  difference     Decimal?  @db.Decimal(12, 2)
  status         String    @default("OPEN")
  note           String?
  paymentSummary Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  movements      CashMovement[]
  sales          Sale[]
  payments       Payment[]

  @@index([companyId, openedAt])
  @@unique([companyId, localId])
}

model CashMovement {
  id         Int       @id @default(autoincrement())
  companyId  Int
  company    Company   @relation(fields: [companyId], references: [id])
  // ID local del POS (SQLite) para poder sincronizar sin duplicar
  localId    Int?
  sessionId  Int
  session    CashSession @relation(fields: [sessionId], references: [id])
  type       String
  movementType String   @default("expense")
  affectsProfit Boolean @default(true)
  amount     Decimal   @db.Decimal(12, 2)
  note       String?
  createdAt  DateTime  @default(now())

  @@index([sessionId])
  @@unique([companyId, localId])
}

model Quote {
  id           Int       @id @default(autoincrement())
  companyId    Int
  company      Company   @relation(fields: [companyId], references: [id])
  // ID local del POS (SQLite) para upsert
  localId      Int
  clientNameSnapshot  String
  clientPhoneSnapshot String?
  clientRncSnapshot   String?
  ticketName   String?
  subtotal     Decimal   @default(0) @db.Decimal(12, 2)
  itbisEnabled Boolean   @default(true)
  itbisRate    Decimal   @default(0.18) @db.Decimal(5, 4)
  itbisAmount  Decimal   @default(0) @db.Decimal(12, 2)
  discountTotal Decimal  @default(0) @db.Decimal(12, 2)
  total        Decimal   @default(0) @db.Decimal(12, 2)
  status       String    @default("OPEN")
  notes        String?
  createdAt    DateTime
  updatedAt    DateTime

  items        QuoteItem[]

  @@unique([companyId, localId])
  @@index([companyId, createdAt])
}

model QuoteItem {
  id          Int      @id @default(autoincrement())
  quoteId     Int
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  // ID local del POS (SQLite)
  localId     Int?
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id])
  productCodeSnapshot String?
  productNameSnapshot String
  description String
  qty         Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal  @db.Decimal(12, 2)
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal  @default(0) @db.Decimal(12, 2)
  discountLine Decimal @default(0) @db.Decimal(12, 2)
  totalLine   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@index([quoteId])
}

model Expense {
  id          Int       @id @default(autoincrement())
  companyId   Int
  company     Company   @relation(fields: [companyId], references: [id])
  createdById Int?
  createdBy   User?     @relation("expense_created_by", fields: [createdById], references: [id])
  amount      Decimal   @db.Decimal(12, 2)
  category    String
  note        String?
  incurredAt  DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId, incurredAt])
}

model Product {
  id         Int       @id @default(autoincrement())
  companyId  Int
  company    Company   @relation(fields: [companyId], references: [id])
  localId    Int?
  code       String
  name       String
  category   String?
  description String?
  price      Decimal   @db.Decimal(12, 2)
  cost       Decimal   @default(0) @db.Decimal(12, 2)
  stock      Decimal   @default(0) @db.Decimal(12, 3)
  imageUrl   String?
  isDemo     Boolean   @default(false)
  isActive   Boolean   @default(true)
  version    Int       @default(0)
  lastModifiedBy String?
  lastClientMutationId String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  saleItems  SaleItem[]
  returnItems ReturnItem[]
  quoteItems QuoteItem[]

  @@unique([companyId, code])
  @@unique([companyId, localId])
  @@index([companyId, isDemo])
  @@index([companyId, deletedAt, updatedAt])
}

model Sale {
  id                   Int         @id @default(autoincrement())
  companyId            Int
  company              Company     @relation(fields: [companyId], references: [id])
  localCode            String
  kind                 String
  status               String      @default("completed")
  customerNameSnapshot String?
  customerPhoneSnapshot String?
  customerRncSnapshot  String?
  itbisEnabled         Boolean     @default(true)
  itbisRate            Decimal     @default(0.18) @db.Decimal(5, 4)
  discountTotal        Decimal     @default(0) @db.Decimal(12, 2)
  subtotal             Decimal     @default(0) @db.Decimal(12, 2)
  itbisAmount          Decimal     @default(0) @db.Decimal(12, 2)
  total                Decimal     @default(0) @db.Decimal(12, 2)
  paymentMethod        String?
  paidAmount           Decimal     @default(0) @db.Decimal(12, 2)
  changeAmount         Decimal     @default(0) @db.Decimal(12, 2)
  creditInterestRate   Decimal     @default(0) @db.Decimal(7, 4)
  creditTermDays       Int?
  creditDueDate        DateTime?
  creditInstallments   Int?
  creditNote           String?
  fiscalEnabled        Boolean     @default(false)
  ncfFull              String?
  ncfType              String?
  sessionId            Int?
  session              CashSession? @relation(fields: [sessionId], references: [id])
  createdById          Int?
  createdBy            User?       @relation("sale_created_by", fields: [createdById], references: [id])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  items                SaleItem[]
  payments             Payment[]
  originalReturns      Return[]     @relation("ReturnOriginalSale")
  generatedReturn      Return?      @relation("ReturnSale")
  electronicInvoices   ElectronicInvoice[]

  @@unique([companyId, localCode])
  @@index([companyId, createdAt])
}

model SaleItem {
  id                     Int      @id @default(autoincrement())
  saleId                 Int
  sale                   Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  localId                Int?
  productId              Int?
  product                Product? @relation(fields: [productId], references: [id])
  productCodeSnapshot    String?
  productNameSnapshot    String
  qty                    Decimal   @db.Decimal(12, 3)
  unitPrice              Decimal   @db.Decimal(12, 2)
  purchasePriceSnapshot  Decimal   @default(0) @db.Decimal(12, 2)
  discountLine           Decimal   @default(0) @db.Decimal(12, 2)
  totalLine              Decimal   @db.Decimal(12, 2)
  createdAt              DateTime  @default(now())
  returnItems            ReturnItem[]

  @@unique([saleId, localId])
  @@index([saleId])
}

model Payment {
  id                   Int              @id @default(autoincrement())
  companyId            Int
  company              Company          @relation(fields: [companyId], references: [id])
  saleId               Int
  sale                 Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  sessionId            Int?
  session              CashSession?     @relation(fields: [sessionId], references: [id])
  localId              Int?
  kind                 String
  method               String
  amount               Decimal          @db.Decimal(12, 2)
  note                 String?
  postedAt             DateTime
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  creditPayment        CreditPayment?
  layawayPayment       LayawayPayment?

  @@unique([companyId, kind, localId])
  @@index([companyId, postedAt])
  @@index([saleId, postedAt])
}

model CreditPayment {
  paymentId             Int      @id
  payment               Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  totalDueSnapshot      Decimal  @default(0) @db.Decimal(12, 2)
  totalPaidSnapshot     Decimal  @default(0) @db.Decimal(12, 2)
  pendingAmountSnapshot Decimal  @default(0) @db.Decimal(12, 2)
}

model LayawayPayment {
  paymentId             Int      @id
  payment               Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  totalDueSnapshot      Decimal  @default(0) @db.Decimal(12, 2)
  totalPaidSnapshot     Decimal  @default(0) @db.Decimal(12, 2)
  pendingAmountSnapshot Decimal  @default(0) @db.Decimal(12, 2)
  statusSnapshot        String?
}

model Return {
  id             Int          @id @default(autoincrement())
  companyId      Int
  company        Company      @relation(fields: [companyId], references: [id])
  localId        Int?
  originalSaleId Int
  originalSale   Sale         @relation("ReturnOriginalSale", fields: [originalSaleId], references: [id])
  returnSaleId   Int          @unique
  returnSale     Sale         @relation("ReturnSale", fields: [returnSaleId], references: [id])
  note           String?
  createdAt      DateTime     @default(now())

  items          ReturnItem[]

  @@unique([companyId, localId])
  @@index([companyId, createdAt])
  @@index([originalSaleId])
}

model ReturnItem {
  id          Int       @id @default(autoincrement())
  returnId    Int
  return      Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  localId     Int?
  saleItemId  Int?
  saleItem    SaleItem? @relation(fields: [saleItemId], references: [id])
  productId   Int?
  product     Product?  @relation(fields: [productId], references: [id])
  description String
  qty         Decimal   @db.Decimal(12, 3)
  price       Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)

  @@unique([returnId, localId])
  @@index([returnId])
}

enum ElectronicInvoiceDirection {
  outbound
  inbound
}

enum ElectronicInvoiceInternalStatus {
  DRAFT
  GENERATED
  SIGNED
  SUBMISSION_PENDING
  SUBMITTED
  ACCEPTED
  ACCEPTED_CONDITIONAL
  REJECTED
  COMMERCIAL_APPROVED
  COMMERCIAL_REJECTED
  VOID_PENDING
  VOIDED
  ERROR
}

enum ElectronicInvoiceCommercialStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ElectronicInvoiceDgiiStatus {
  NOT_SENT
  RECEIVED
  IN_PROCESS
  ACCEPTED
  ACCEPTED_CONDITIONAL
  REJECTED
  ERROR
}

enum ElectronicSequenceStatus {
  ACTIVE
  PAUSED
  EXHAUSTED
  INACTIVE
}

enum ElectronicCertificateStatus {
  ACTIVE
  EXPIRED
  REVOKED
  INACTIVE
  INVALID
}

enum ElectronicAuditSeverity {
  INFO
  WARN
  ERROR
  CRITICAL
}

model ElectronicInvoice {
  id                    Int                              @id @default(autoincrement())
  companyId             Int
  company               Company                          @relation(fields: [companyId], references: [id])
  branchId              Int                              @default(0)
  saleId                Int?
  sale                  Sale?                            @relation(fields: [saleId], references: [id], onDelete: SetNull)
  originalInvoiceId     Int?
  originalInvoice       ElectronicInvoice?               @relation("ElectronicInvoiceCorrection", fields: [originalInvoiceId], references: [id], onDelete: SetNull)
  corrections           ElectronicInvoice[]              @relation("ElectronicInvoiceCorrection")
  certificateId         Int?
  certificate           ElectronicCertificate?           @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  direction             ElectronicInvoiceDirection
  documentTypeCode      String
  ecf                   String
  sequenceNumber        Int
  issuerRnc             String
  issuerName            String
  buyerRnc              String?
  buyerName             String?
  issueDate             DateTime
  totalAmount           Decimal                          @db.Decimal(14, 2)
  taxAmount             Decimal                          @db.Decimal(14, 2)
  currencyCode          String                           @default("DOP")
  xmlUnsigned           String?
  xmlSigned             String?
  xmlHash               String?
  dgiiTrackId           String?
  dgiiStatus            ElectronicInvoiceDgiiStatus      @default(NOT_SENT)
  commercialStatus      ElectronicInvoiceCommercialStatus @default(NONE)
  internalStatus        ElectronicInvoiceInternalStatus  @default(DRAFT)
  rejectionCode         String?
  rejectionMessage      String?
  dgiiRawResponseJson   Json?
  signedAt              DateTime?
  submittedAt           DateTime?
  acceptedAt            DateTime?
  rejectedAt            DateTime?
  canceledAt            DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt

  statusHistory         ElectronicInvoiceStatusHistory[]
  auditLogs             ElectronicAuditLog[]

  @@unique([companyId, ecf])
  @@index([companyId, direction, createdAt])
  @@index([companyId, internalStatus, createdAt])
  @@index([companyId, dgiiTrackId])
  @@index([saleId])
}

model ElectronicInvoiceStatusHistory {
  id                 Int               @id @default(autoincrement())
  electronicInvoiceId Int
  electronicInvoice  ElectronicInvoice @relation(fields: [electronicInvoiceId], references: [id], onDelete: Cascade)
  fromStatus         String?
  toStatus           String
  note               String?
  rawPayloadJson     Json?
  createdAt          DateTime          @default(now())
  createdBy          String?

  @@index([electronicInvoiceId, createdAt])
}

model ElectronicSequence {
  id               Int                    @id @default(autoincrement())
  companyId        Int
  company          Company                @relation(fields: [companyId], references: [id])
  branchId         Int                    @default(0)
  documentTypeCode String
  prefix           String
  currentNumber    BigInt                 @default(0) @db.BigInt
  maxNumber        BigInt                 @db.BigInt
  status           ElectronicSequenceStatus @default(ACTIVE)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([companyId, branchId, documentTypeCode])
  @@index([companyId, status])
}

model ElectronicCertificate {
  id                Int                      @id @default(autoincrement())
  companyId         Int
  company           Company                  @relation(fields: [companyId], references: [id])
  alias             String
  filePath          String?
  secretReference   String?
  passwordEncrypted String
  serialNumber      String
  issuer            String
  subject           String
  validFrom         DateTime
  validTo           DateTime
  status            ElectronicCertificateStatus @default(ACTIVE)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  invoices          ElectronicInvoice[]

  @@unique([companyId, alias])
  @@index([companyId, status])
}

model ElectronicInboundEndpointConfig {
  id               Int       @id @default(autoincrement())
  companyId        Int
  company          Company   @relation(fields: [companyId], references: [id])
  branchId         Int       @default(0)
  authEnabled      Boolean   @default(true)
  authPath         String
  receptionPath    String
  approvalPath     String
  publicBaseUrl    String
  active           Boolean   @default(true)
  outboundEnabled  Boolean   @default(false)
  environment      String    @default("precertification")
  tokenTtlSeconds  Int       @default(300)
  signerFullName   String?
  signerDocumentType String?
  signerDocumentNumber String?
  signerAuthorizedForDgii Boolean @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([companyId, branchId])
}

model ElectronicDgiiTokenCache {
  id              Int      @id @default(autoincrement())
  companyId       Int
  company         Company  @relation(fields: [companyId], references: [id])
  environment     String
  tokenEncrypted  String
  issuedAt        DateTime @default(now())
  expiresAt       DateTime
  lastValidatedAt DateTime?
  lastErrorCode   String?
  lastErrorMessage String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, environment])
  @@index([companyId, expiresAt])
}

model ElectronicAuditLog {
  id           Int                   @id @default(autoincrement())
  companyId    Int
  company      Company               @relation(fields: [companyId], references: [id])
  invoiceId    Int?
  invoice      ElectronicInvoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  eventType    String
  eventSource  String
  severity     ElectronicAuditSeverity @default(INFO)
  message      String
  payloadJson  Json?
  requestId    String?
  createdAt    DateTime              @default(now())

  @@index([companyId, createdAt])
  @@index([invoiceId, createdAt])
}

model ElectronicAuthSeed {
  id            String    @id @default(cuid())
  companyId     Int
  company       Company   @relation(fields: [companyId], references: [id])
  nonce         String
  challengeHash String
  expiresAt     DateTime
  validatedAt   DateTime?
  usedAt        DateTime?
  tokenHash     String?
  createdAt     DateTime  @default(now())

  @@index([companyId, expiresAt])
}

model DgiiCertificationBatch {
  id              Int      @id @default(autoincrement())
  companyId       Int
  company         Company  @relation(fields: [companyId], references: [id])
  rnc             String?
  fileName        String
  uploadedAt      DateTime @default(now())
  status          String   @default("IMPORTED")
  totalCases      Int      @default(0)
  ecfCases        Int      @default(0)
  rfceCases       Int      @default(0)
  rawMetadataJson Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cases           DgiiCertificationCase[]

  @@index([companyId, uploadedAt])
  @@index([companyId, status])
}

model DgiiCertificationCase {
  id                 Int      @id @default(autoincrement())
  batchId            Int
  batch              DgiiCertificationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  companyId          Int
  company            Company  @relation(fields: [companyId], references: [id])
  sheetName          String
  rowNumber          Int
  encf               String?
  tipoEcf            String?
  rncEmisor          String?
  rncComprador       String?
  fechaEmision       DateTime?
  montoTotal         Decimal? @db.Decimal(14, 2)
  rawRowJson         Json
  status             String   @default("IMPORTED")
  xmlGenerated       String?
  xmlSigned          String?
  trackId            String?
  dgiiRawResponseJson Json?
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId, batchId])
  @@index([companyId, status])
  @@index([companyId, sheetName])
  @@index([companyId, encf])
}
