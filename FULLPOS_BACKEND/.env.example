NODE_ENV=development
PORT=4000

# Base de datos
DATABASE_URL=postgres://USER:PASS@HOST:5432/DB_NAME

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# CORS y descargas
CORS_ORIGINS=http://localhost:3000
OVERRIDE_API_KEY=change-me-override-key
VIRTUAL_TOKEN_MASTER_KEY=change-me-virtual-token-master-key
OWNER_APP_ANDROID_URL=https://example.com/fullpos-owner.apk
OWNER_APP_IOS_URL=https://example.com/fullpos-owner.ipa
OWNER_APP_VERSION=1.0.0
